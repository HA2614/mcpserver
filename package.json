{
  "name": "mcp-project-manager",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "backend",
    "frontend"
  ],
  "scripts": {
    "dev": "npm-run-all --parallel dev:backend dev:frontend",
    "dev:backend": "npm --workspace backend run dev",
    "dev:frontend": "npm --workspace frontend run dev",
    "migrate": "npm --workspace backend run migrate",
    "terminal": "npm --workspace backend run terminal",
    "mcp": "npm --workspace backend run mcp",
    "build": "npm --workspace frontend run build",
    "start": "npm --workspace backend run start",
    "desktop": "python desktop/launcher.py",
    "desktop:start": "python desktop/launcher.py --start-backend --backend-cwd ."
  },
  "devDependencies": {
    "npm-run-all": "^4.1.5"
  }
}
